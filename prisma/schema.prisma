generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tutorials    Tutorial[]
  beatProgress UserBeatProgress[]
}

model Tutorial {
  id          String    @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime  @default(now())

  authorId String
  author   User     @relation(fields: [authorId], references: [id])

  nilais Nilai[]
}

model Nilai {
  id        String   @id @default(cuid())
  name      String
  order     Int
  createdAt DateTime @default(now())

  tutorialId String
  tutorial   Tutorial @relation(fields: [tutorialId], references: [id])

  beats Beat[]
}

model Beat {
  id        String   @id @default(cuid())
  name      String
  type      String
  order     Int      @default(0)
  timing    Int?
  audioUrl  String?
  createdAt DateTime @default(now())

  nilaiId String
  nilai   Nilai @relation(fields: [nilaiId], references: [id])

  userProgress UserBeatProgress[]
}

model UserBeatProgress {
  id        String   @id @default(cuid())
  userId    String
  beatId    String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  beat Beat @relation(fields: [beatId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, beatId])
}
